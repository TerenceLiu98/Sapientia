{
	"name": "@sapientia/api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"build": "bun build src/index.ts --target=bun --outdir=dist",
		"start": "bun dist/index.js",
		"worker:dev": "bun src/worker.ts",
		"worker:start": "bun src/worker.ts",
		"audit:reader-annotations": "node --experimental-strip-types scripts/audit-reader-annotations.ts",
		"audit:paper-compile": "bun scripts/audit-paper-compile.ts",
		"audit:concept-salience": "bun scripts/audit-concept-salience.ts",
		"backfill:paper-compile": "bun scripts/backfill-paper-compile.ts",
		"backfill:concept-salience": "bun scripts/backfill-concept-salience.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^2.0.0",
		"@ai-sdk/openai-compatible": "^1.0.0",
		"@aws-sdk/client-s3": "^3.1037.0",
		"@aws-sdk/s3-request-presigner": "^3.1037.0",
		"@sapientia/db": "workspace:*",
		"@sapientia/shared": "workspace:*",
		"ai": "^5.0.0",
		"better-auth": "^1.6.9",
		"bullmq": "^5.76.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.6.0",
		"ioredis": "^5.10.1",
		"pdf-lib": "^1.17.1",
		"pdf-parse": "^2.4.5",
		"pino": "^10.3.1",
		"yauzl": "^3.3.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@testcontainers/postgresql": "^11.14.0",
		"@testcontainers/redis": "^11.14.0",
		"@types/bun": "latest",
		"@types/node": "^24.12.2",
		"@types/yauzl": "^2.10.3",
		"@types/yazl": "^3.3.1",
		"pino-pretty": "^13.1.3",
		"testcontainers": "^11.14.0",
		"typescript": "^5.6.0",
		"vitest": "^4.1.5",
		"yazl": "^3.3.1"
	}
}
