{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"lib": ["ES2022"],
		"types": ["node"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		"allowImportingTsExtensions": true,
		"moduleDetection": "force",
		"noEmit": true
	},
	"include": ["vite.config.ts", "vitest.config.ts"]
}
