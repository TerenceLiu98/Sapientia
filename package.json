{
	"name": "sapientia",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"dev:web": "pnpm --filter @sapientia/web dev",
		"dev:api": "pnpm --filter @sapientia/api dev",
		"worker:dev": "pnpm --filter @sapientia/api worker:dev",
		"infra:up": "docker compose -f infra/docker/docker-compose.yml up -d --build",
		"infra:down": "docker compose -f infra/docker/docker-compose.yml down",
		"infra:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
		"db:generate": "pnpm --filter @sapientia/db db:generate",
		"db:migrate": "pnpm --filter @sapientia/db db:migrate",
		"db:studio": "pnpm --filter @sapientia/db db:studio",
		"build": "pnpm -r build",
		"typecheck": "pnpm -r typecheck",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "pnpm -r test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"typescript": "^5.6.0"
	}
}
