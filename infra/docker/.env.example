# Copy this file to `infra/docker/.env` and start Compose with:
# `docker compose --env-file infra/docker/.env -f infra/docker/docker-compose.yml up -d --build`.
#
# Replace every secret before exposing a deployment outside your machine.
# This file is for Docker only; `apps/api/.env` is for local pnpm dev and uses
# different auth origins.

WEB_PORT=8080
API_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_STORAGE_IMAGE_TAG=latest
S3_SERVER_DOMAINS=localhost,object-storage

POSTGRES_DB=sapientia
POSTGRES_PASSWORD=change_me_postgres_password

S3_ACCESS_KEY_ID=sapientia_s3
S3_SECRET_ACCESS_KEY=change_me_s3_password
S3_BUCKET=sapientia
S3_REGION=us-east-1

# Public browser-facing app URL. In local compose this is the nginx web service.
# These must exactly match the browser origin users open. If WEB_PORT changes,
# update both values to the same scheme/host/port, or better-auth will reject
# sign-in/sign-up requests with "Invalid origin".
BETTER_AUTH_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080

# Public browser-facing object storage URL used in presigned PDF URLs.
# For local compose this can be localhost; in production set it to your RustFS/S3 ingress.
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_a_real_secret_at_least_32_chars
ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

LOG_LEVEL=info
MINERU_BASE_URL=https://mineru.net

# Optional OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional metadata enrichment.
SEMANTIC_SCHOLAR_API_KEY=
